# ============================================================
# Voicebox — ROCm-enabled image for AMD GPUs
# 3-stage build: Frontend → Python deps → Runtime
# ============================================================

# === Stage 1: Build frontend ===
FROM oven/bun:1 AS frontend

WORKDIR /build

COPY package.json bun.lock CHANGELOG.md ./
COPY app/ ./app/
COPY web/ ./web/

RUN sed -i '/"tauri"/d; /"landing"/d' package.json && \
    sed -i -z 's/,\n  ]/\n  ]/' package.json
RUN bun install --no-save
RUN cd web && bunx --bun vite build


# === Stage 2: Build Python dependencies ===
# Use the ROCm PyTorch image that ships HIP libraries pre-compiled for AMD GPUs.
# This avoids the "torch.cuda.is_available() == False" problem caused by
# missing kernels in the generic rocm/dev-ubuntu base image.
FROM rocm/pytorch:rocm7.2.1_ubuntu24.04_py3.12_pytorch_release_2.9.1 AS backend-builder

ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ffmpeg \
    git \
    && rm -rf /var/lib/apt/lists/*

# PyTorch ROCm is already installed in the base image — verify it works.
RUN python3 - <<'PY'
import torch
assert torch.cuda.is_available(), "torch.cuda.is_available() must be True in the builder"
print("ROCm torch build:", torch.__version__, torch.version.hip)
print("GPU count:", torch.cuda.device_count())
print("GPU 0:", torch.cuda.get_device_name(0))
PY

# Create a venv so we can install voicebox deps without touching the system Python.
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN pip install --no-cache-dir --upgrade pip setuptools wheel

COPY backend/requirements.txt .
RUN python3 - <<'PY'
from pathlib import Path
req_path = Path('requirements.txt')
lines = []
for line in req_path.read_text().splitlines():
    stripped = line.strip()
    if not stripped or stripped.startswith('#'):
        lines.append(line)
        continue
    if stripped.startswith(('torch', 'torchaudio')):
        continue
    lines.append(line)
Path('/tmp/requirements-no-torch.txt').write_text('\n'.join(lines) + '\n')
PY

RUN pip install --no-cache-dir -r /tmp/requirements-no-torch.txt
RUN pip install --no-cache-dir --no-deps chatterbox-tts
RUN pip install --no-cache-dir --no-deps hume-tada
RUN pip install --no-cache-dir git+https://github.com/QwenLM/Qwen3-TTS.git


# === Stage 3: Runtime ===
FROM rocm/pytorch:rocm7.2.1_ubuntu24.04_py3.12_pytorch_release_2.9.1

ENV DEBIAN_FRONTEND=noninteractive
ENV ROCM_HOME=/opt/rocm
ENV PATH=/opt/rocm/bin:${PATH}
ENV LD_LIBRARY_PATH=/opt/rocm/lib:${LD_LIBRARY_PATH}
ENV HOME=/home/voicebox
ENV HF_HOME=/home/voicebox/.cache/huggingface
ENV HF_HUB_CACHE=/home/voicebox/.cache/huggingface/hub
ENV HUGGINGFACE_HUB_CACHE=/home/voicebox/.cache/huggingface/hub
ENV TRANSFORMERS_CACHE=/home/voicebox/.cache/transformers

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

RUN if ! getent group voicebox >/dev/null; then \
        if ! getent group 1000 >/dev/null; then groupadd -r -g 1000 voicebox; else groupadd -r voicebox; fi; \
    fi && \
    if ! id -u voicebox >/dev/null 2>&1; then \
        if ! getent passwd 1000 >/dev/null; then useradd -r -u 1000 -g voicebox -m -s /bin/bash voicebox; else useradd -r -g voicebox -m -s /bin/bash voicebox; fi; \
    fi && \
    if id -u voicebox >/dev/null 2>&1; then usermod -u 1000 voicebox >/dev/null 2>&1 || true; fi && \
    if getent group voicebox >/dev/null; then groupmod -g 1000 voicebox >/dev/null 2>&1 || true; fi

WORKDIR /app

COPY --from=backend-builder /opt/venv /opt/venv
COPY --chown=voicebox:voicebox backend/ /app/backend/
COPY --from=frontend --chown=voicebox:voicebox /build/web/dist /app/frontend/

ENV VIRTUAL_ENV=/opt/venv
ENV PATH=/opt/venv/bin:${PATH}

RUN mkdir -p /app/data/generations /app/data/profiles /app/data/cache \
    /home/voicebox/.cache/huggingface /home/voicebox/.cache/transformers \
    && chown -R "$(id -u voicebox):$(id -g voicebox)" /app/data /home/voicebox/.cache/huggingface /home/voicebox/.cache/transformers \
    && usermod -d /home/voicebox voicebox

USER voicebox

EXPOSE 17493

HEALTHCHECK --interval=30s --timeout=10s --retries=3 --start-period=60s \
    CMD curl -f http://localhost:17493/health || exit 1

CMD ["/opt/venv/bin/python", "-m", "uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "17493"]
